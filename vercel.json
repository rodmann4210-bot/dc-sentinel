// ── SCORE ALL SIGNALS ─────────────────────────────────────────
function scoreSignals(readings) {
  const scores = {};
  const alerts = [];

  for (const [key, bl] of Object.entries(BASELINES)) {
    const val = readings[key];
    if (val === null || val === undefined) continue;
    const z = zScore(val, bl);
    const label = sigmaLabel(z);
    scores[key] = { value: val, z: +z.toFixed(2), label, weight: WEIGHTS[key] || 0 };
    if (Math.abs(z) >= 2) {
      alerts.push({ signal: key, z: +z.toFixed(2), label, value: val });
    }
  }

  const zValues = Object.values(scores).map(s => Math.abs(s.z));
  const peakZ = zValues.length ? Math.max(...zValues) : 0;
  const coverage = Object.keys(scores).reduce((sum, k) => sum + (WEIGHTS[k] || 0), 0);
  const coveragePct = Math.round((coverage / Object.values(WEIGHTS).reduce((a, b) => a + b, 0)) * 100);

  return { scores, alerts, peakZ: +peakZ.toFixed(2), coveragePct };
}

module.exports = {
  fetchAircraft,
  fetchFederalRegister,
  fetchTFRs,
  fetchHotelRate,
  fetchCarRental,
  scoreSignals,
  zScore,
  sigmaLabel,
  BASELINES,
  WEIGHTS,
};
